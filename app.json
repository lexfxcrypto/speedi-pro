{
  "expo": {
    "name": "speedi-pro",
    "slug": "speedi-pro",
    "scheme": "speedipro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Speedi uses your location to show customers where you are when you're available for work.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.speeditrades.speedipro"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2ecc8854-c724-469e-afa3-711f4f103122"
      }
    },
    "owner": "speeditrades"
  }
}
